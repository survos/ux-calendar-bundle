{
    "name": "tacman/ux-calendar-demo",
    "description": "Demo app for survos/ux-calendar-bundle",
    "type": "project",
    "license": "MIT",
    "minimum-stability": "dev",
    "prefer-stable": true,
    "require": {
        "php": "^8.4",
        "symfony/asset-mapper": "^8.0",
        "symfony/dotenv": "^8.0",
        "symfony/flex": "^2.10",
        "symfony/framework-bundle": "*",
        "symfony/runtime": "^8.0",
        "symfony/stimulus-bundle": "^2.34",
        "symfony/twig-bundle": "^8.0",
        "symfony/ux-twig-component": "^2.8",
        "symfony/yaml": "^8.0",
        "survos/core-bundle": "^2.0",
        "survos/ux-calendar-bundle": "*",
        "twig/twig": "^3.4",
        "symfony/console": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^13"
    },
    "repositories": [
        {
            "type": "path",
            "url": ".."
        }
    ],
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "config": {
        "allow-plugins": {
            "symfony/flex": true,
            "symfony/runtime": true
        }
    },
    "scripts": {
        "auto-scripts": {
            "cache:clear": "symfony-cmd",
            "assets:install %PUBLIC_DIR%": "symfony-cmd",
            "importmap:install": "symfony-cmd"
        }
    }
}
